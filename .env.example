# Telegram Bot API token
TELEGRAM_TOKEN=

# Comma-separated Telegram user IDs that can use admin features
ADMIN_IDS=

# Telegram MTProto credentials from my.telegram.org
APP_ID=
APP_HASH=

# Optional phone number for MTProto auth/account binding
PHONE_NUMBER=

# Redis settings for search cache
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Search result cache TTL in seconds
CACHE_TTL=3600

# Optional SOCKS5 proxy for all OSINT HTTP calls (example: socks5://127.0.0.1:9050)
PROXY_URL=

# MTProto client pool size
MTPROTO_POOL_SIZE=3

# External API keys (optional but recommended)
HIBP_API_KEY=
LEAKCHECK_API_KEY=

# Bot semantic version used in /status
BOT_VERSION=1.0.0

# Search reliability controls
SEARCH_TIMEOUT_SEC=45
SOURCE_TIMEOUT_SEC=12
SOURCE_RETRY_COUNT=2
SOURCE_RETRY_BACKOFF_MS=350
SOURCE_MAX_PARALLEL=6
USER_RATE_LIMIT_MS=1200
